# API Keys for LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Configuration
DEFAULT_MODEL=gpt-4-turbo-preview
TEMPERATURE=0.7
MAX_TOKENS=2000

# Local Model Configuration (Alternative to OpenAI)
# Set to true to use local LLM instead of OpenAI API
USE_LOCAL_MODEL=false
# Specify which local model to use (default: TinyLlama/TinyLlama-1.1B-Chat-v1.0)
# Other options: microsoft/phi-2, meta-llama/Llama-2-7b-chat-hf, etc.
LOCAL_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Application Settings
LOG_LEVEL=INFO
DATA_DIR=./data
REPORTS_DIR=./data/reports

# Optional: Azure OpenAI (if using Azure)
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=your_azure_endpoint
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name
